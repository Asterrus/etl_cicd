{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
      "description": "Количество часов с момента последней загрузки данных. Порог: 24 часа.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "hours",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 24 }
            ]
          },
          "unit": "h"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
          "format": "time_series",
          "rawSql": "SELECT checked_at AS \"time\", value AS \"hours since last load\"\nFROM dwh.data_quality_checks\nWHERE check_name = 'freshness'\n  AND $__timeFilter(checked_at)\nORDER BY checked_at",
          "refId": "A"
        }
      ],
      "title": "Data Freshness",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
      "description": "Последний результат каждой проверки качества данных.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "OK":   { "color": "green", "index": 0, "text": "OK" },
                      "FAIL": { "color": "red",   "index": 1, "text": "FAIL" }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
          "format": "table",
          "rawSql": "SELECT DISTINCT ON (check_name)\n  check_name AS \"Check\",\n  status AS \"Status\",\n  value AS \"Value\",\n  checked_at AS \"Checked At\"\nFROM dwh.data_quality_checks\nORDER BY check_name, checked_at DESC",
          "refId": "A"
        }
      ],
      "title": "Latest Check Status",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
      "description": "Текущее количество строк в таблицах источника (OLTP). Растёт по мере работы генератора данных.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rows" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "cellHeight": "sm", "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
          "format": "table",
          "rawSql": "SELECT 'source.Customers' AS \"Table\", COUNT(*) AS \"Rows\" FROM source.Customers\nUNION ALL\nSELECT 'source.Products', COUNT(*) FROM source.Products\nUNION ALL\nSELECT 'source.Sales', COUNT(*) FROM source.Sales\nORDER BY \"Table\"",
          "refId": "A"
        }
      ],
      "title": "Source Tables (OLTP)",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
      "description": "Текущее количество строк в таблицах хранилища (DWH). Растёт после каждого запуска ETL.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rows" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "cellHeight": "sm", "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "etl_dq_postgres" },
          "format": "table",
          "rawSql": "SELECT 'dwh.Customer_Dim' AS \"Table\", COUNT(*) AS \"Rows\" FROM dwh.Customer_Dim\nUNION ALL\nSELECT 'dwh.Product_Dim', COUNT(*) FROM dwh.Product_Dim\nUNION ALL\nSELECT 'dwh.Sales_Fact', COUNT(*) FROM dwh.Sales_Fact\nORDER BY \"Table\"",
          "refId": "A"
        }
      ],
      "title": "DWH Tables",
      "type": "table"
    }
  ],
  "schemaVersion": 42,
  "tags": [],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
